<% layout("./layouts/boilerplate") %>

  <style>
    #filters {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 1.25rem;
      padding: 1rem;
      background: white;
      border-bottom: 1px solid #ebebeb;
    }

    .filter {
      text-align: center;
      opacity: 0.6;
      transition: opacity 0.2s ease;
      padding: 0.25rem 0.5rem;
    }

    .filter:hover {
      opacity: 1;
      cursor: pointer;
    }

    .filter i {
      font-size: 1.3rem;
      margin-bottom: 0.25rem;
    }

    .filter a {
      text-decoration: none;
      color: #222;
    }

    .filter p {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.3px;
      margin: 0;
    }

    .filter:hover p {
      text-decoration: underline;
    }

    .tax-switch {
      display: flex;
      align-items: center;
      padding: 0.4rem 0.9rem;
      border-radius: 999px;
      border: 1px solid #dddddd;
      background: #fff;
      cursor: pointer;
    }

    .form-check-label {
      font-size: 0.85rem;
      font-weight: 500;
    }

    .listing-card {
      border: none;
      background: transparent;
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

    .listing-card:hover {
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
      transform: translateY(-3px);
    }

    .card-img-top {
      height: 250px;
      object-fit: cover;
      border-radius: 12px;
    }

    .card-body {
      padding: 0.75rem 0;
      background: transparent;
    }

    .card-text {
      font-size: 0.9rem;
      color: #222;
    }

    .card-text b {
      font-size: 1rem;
      font-weight: 600;
    }

    .tax-info {
      display: none;
      font-size: 0.8rem;
      color: #717171;
    }

    .row {
      row-gap: 2rem;
    }

    .no-results {
      text-align: center;
      margin: 2rem 0;
      font-size: 1rem;
      color: #888;
    }

    @media (max-width: 768px) {
      .filter {
        flex: 1 1 40%;
      }

      .tax-switch {
        width: 100%;
        justify-content: center;
        margin-top: 0.5rem;
      }
    }
  </style>

  <div id="filters">
    <% const categories=[ { name: "Trending" , icon: "fa-fire" }, { name: "Rooms" , icon: "fa-bed" }, {
      name: "Iconic Cities" , icon: "fa-mountain-city" }, { name: "Mountains" , icon: "fa-mountain" }, { name: "Castles"
      , icon: "fa-fort-awesome" }, { name: "Amazing Pools" , icon: "fa-person-swimming" }, { name: "Camping" ,
      icon: "fa-campground" }, { name: "Farms" , icon: "fa-cow" }, { name: "Arctic" , icon: "fa-snowflake" }, {
      name: "Domes" , icon: "fa-igloo" } ]; %>

      <% for (let category of categories) { %>
        <div class="filter">
          <a href="/listings/category/<%= category.name %>">
            <i class="fa-solid <%= category.icon %>"></i>
            <p>
              <%= category.name %>
            </p>
          </a>
        </div>
        <% } %>

          <div class="tax-switch">
            <div class="form-check form-switch m-0">
              <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" />
              <label class="form-check-label ms-2" for="flexSwitchCheckDefault">
                Display total after taxes
              </label>
            </div>
          </div>
  </div>

  <% if (searchQuery) { %>
    <div class="search-message text-center my-3">
      Showing results for "<%= searchQuery %>"
    </div>
    <% } %>

      <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-4">
        <% if (allListings && allListings.length> 0) { %>
          <% allListings.forEach(listing=> { %>
            <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
              <div class="card listing-card">
              <img
  src="<%= (listing.image?.url || '/images/default.jpg')
    .replace('/upload','/upload/w_400,h_300,c_fill,q_auto,f_auto') %>"
  class="card-img-top"
  alt="<%= listing.title %> image"
  loading="lazy"
/>
                <div class="card-body">
                  <p class="card-text mb-1">
                    <b>
                      <%= listing.title %>
                    </b>
                  </p>
                  <p class="card-text" data-base="<%= listing.price %>">
                    &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
                      <i class="tax-info">&nbsp;+18% GST</i>
                  </p>
                </div>
              </div>
            </a>
            <% }) %>
              <% } else { %>
                <div class="no-results">No destinations found 😔</div>
                <% } %>
      </div>

      <script>
        const taxSwitch = document.getElementById("flexSwitchCheckDefault");
        if (taxSwitch) {
          taxSwitch.addEventListener("change", () => {
            const taxInfo = document.getElementsByClassName("tax-info");
            for (let info of taxInfo) {
              info.style.display = info.style.display === "inline" ? "none" : "inline";
            }
          });
        }
      </script>

      <div id="searchQueryFlag" data-exists="<%= searchQuery ? 'true' : 'false' %>"></div>
      <script>
        const searchQueryDiv = document.getElementById("searchQueryFlag");
        const searchQueryExists = searchQueryDiv.dataset.exists === "true";

        if (searchQueryExists) {
          window.history.replaceState({}, document.title, "/listings");
        }
      </script>