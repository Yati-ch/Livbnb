<% layout("./layouts/boilerplate") %>

<style>
    .show-card {
        padding: 0;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 2rem;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
    }

    .show-img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
    }

    .card-body {
        padding: 1rem 1.25rem;
        background: #fff;
        text-align: center;
    }

    .card-body p {
        margin: 0.25rem 0;
        color: #222;
    }

    /* ================= REVIEW FORM ================= */
    .review-form {
        max-width: 700px;
        margin: 2rem auto;
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid #ebebeb;
        background: #fff;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04);
    }

    .review-form h4 {
        margin-bottom: 1rem;
        font-weight: 600;
        text-align: center;
    }

    .review-form textarea,
    .review-form input {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 0.6rem 0.75rem;
        font-size: 0.95rem;
        width: 100%;
    }

    .review-form textarea:focus,
    .review-form input:focus {
        outline: none;
        border-color: #ff385c;
        box-shadow: 0 0 0 1px #ff385c;
    }

    .review-form button {
        background-color: #ff385c;
        color: #fff;
        border-radius: 999px;
        border: none;
        font-weight: 600;
        padding: 0.45rem 1.2rem;
        font-size: 1rem;
        margin-top: 1rem;
        display: inline-block;
    }

    .review-form button:hover {
        background-color: #e31c5f;
    }

    .reviews-wrapper {
        max-width: 900px;
        margin: 3rem auto 0;
    }

    .review-card {
        background: #ffffff;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
        border: 1px solid #eaeaea;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

    .review-card:hover {
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
    }

    .review-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.4rem;
    }

    .review-user {
        font-weight: 600;
        color: #222;
        font-size: 0.95rem;
    }

    .review-stars {
        color: #ffb400;
        font-size: 0.85rem;
    }

    .review-text {
        font-size: 0.95rem;
        color: #555;
        line-height: 1.55;
        margin-top: 0.5rem;
    }

    .review-delete-btn {
        background-color: #ff385c;
        border: none;
        color: #fff;
        font-size: 0.8rem;
        padding: 0.35rem 0.8rem;
        border-radius: 6px;
        margin-top: 0.5rem;
    }

    .review-delete-btn:hover {
        color: #ff385c;
        text-decoration: underline;
    }

    @media (max-width: 768px) {
        .review-form {
            margin: 1rem;
            padding: 1rem;
        }
    }
</style>

<body>
    <div class="container mt-4">

        <!-- Listing Title -->
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h3><b><%= listing.title %></b></h3>
            </div>
        </div>

        <!-- Listing Card -->
        <div class="card col-lg-6 col-md-8 col-sm-10 mx-auto show-card">
            <img src="<%= listing.image?.url || '/images/default.jpg' %>" class="show-img" alt="listing_image">
            <div class="card-body">
<p>
  Owned By
  <i><%= listing.owner ? listing.owner.username : "Unknown Host" %></i>
</p>
                <p><%= listing.description %></p>
                <p>&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</p>
                <p><%= listing.location %>, <%= listing.country %></p>
            </div>
        </div>

        <!-- Owner Actions -->
        <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
            <div class="d-flex justify-content-center mt-3 gap-2">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
                <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
                    <button class="btn btn-danger">Delete</button>
                </form>
            </div>
        <% } %>

        <!-- Review Form -->
        <% if (currUser) { %>
            <div class="review-form">
                <h4>Leave a review</h4>
                <form action="/listings/<%= listing._id %>/reviews" method="post">
                    <fieldset class="starability-slot mb-3">
                        <% for(let i=1; i<=5; i++) { %>
                            <input type="radio" id="rate<%= i %>" name="review[rating]" value="<%= i %>" <%= i===1 ? 'checked' : '' %>>
                            <label for="rate<%= i %>"><%= i %> star<%= i>1 ? '' : 's' %></label>
                        <% } %>
                    </fieldset>
                    <textarea name="review[comment]" rows="3" required placeholder="Share your experience..."></textarea>
                    <div class="text-center">
                        <button type="submit">Submit review</button>
                    </div>
                </form>
            </div>
        <% } %>

        <!-- Reviews List -->
        <% if (listing.reviews && listing.reviews.length > 0) { %>
            <div class="reviews-wrapper">
                <h4 class="text-center mb-4">⭐ <%= listing.reviews.length %> reviews</h4>
                <div class="row justify-content-center">
                    <% for (let review of listing.reviews) { %>
                        <div class="col-lg-6 col-md-8 col-sm-10">
                            <div class="review-card">
                                <div class="review-header">
                                    <span class="review-user"><i class="fa-solid fa-user-circle"></i> <%= review.author.username %></span>
                                    <div class="review-stars">
                                        <% for(let i=1; i<=5; i++) { %>
                                            <% if(i <= review.rating) { %>
                                                <i class="fa-solid fa-star"></i>
                                            <% } else { %>
                                                <i class="fa-regular fa-star"></i>
                                            <% } %>
                                        <% } %>
                                    </div>
                                </div>
                                <p class="review-text"><%= review.comment %></p>

                                <% if(currUser && currUser._id.equals(review.author._id)) { %>
                                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
                                        <button class="review-delete-btn">Delete</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>

    </div>
</body>
